# ─── Frontend (safe to expose — Vite inlines VITE_* into the client bundle) ───
# Your Supabase project URL and anon/public key.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Server only (Supabase Edge Function secrets — NEVER expose to frontend) ───
# Set these with:  supabase secrets set KEY=value
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot API — used only inside the Edge Function.
# Recipients are chat IDs (Grandma = Nonna, Mum = Iliana). Never hardcode these.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_MUM_CHAT_ID=
TELEGRAM_GRANDMA_CHAT_ID=

# Notification channel selector. "telegram" for real messages, "mock" for local/dev/tests
# (records to notifications_log without sending). Lets us swap the channel later.
NOTIFY_PROVIDER=mock

# Shared secret protecting the scheduled function endpoint (set the same value with
# `supabase secrets set CRON_SECRET=...`).
CRON_SECRET=some-long-random-string

# Deployed frontend URL (no trailing slash, set with `supabase secrets set APP_URL=...`).
# Optional — when set, Telegram messages include a one-tap button straight into the app.
APP_URL=https://your-app.vercel.app
